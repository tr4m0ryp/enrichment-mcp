# enrichment_mcp server environment. Copy to .env and fill in real values.

# Full Postgres DSN for the Supabase lead store (required).
SUPABASE_DB_URL=postgresql://HOST:5432/DBNAME

# Prospeo enrich-person API keys, comma-separated (free-tier key pool).
PROSPEO_API_KEYS=key_one,key_two

# Pull mobile numbers too (costs 10x credits). Leave false for email+LinkedIn.
PROSPEO_ENRICH_MOBILE=false

# MyEmailVerifier API key for the guess+verify fallback (verify_email tool).
MYEMAILVERIFIER_API_KEY=your_myemailverifier_key

# --- Auth: choose ONE mode ---
#
# Mode A (Claude Code): static bearer. Leave MCP_OAUTH_PROVIDER empty and set a
# long random token. Claude Code sends it as an Authorization header.
MCP_BEARER_TOKEN=generate_a_long_random_token
#
# Mode B (claude.ai web connector): OAuth. The web app cannot send a bearer, so
# it needs OAuth. Set MCP_OAUTH_PROVIDER and MCP_BASE_URL (the public https URL
# of THIS server, no /mcp). Then either:
#   supabase -> reuse the project's own Supabase Auth (no separate IdP):
#     MCP_OAUTH_PROVIDER=supabase
#     SUPABASE_PROJECT_URL=https://<ref>.supabase.co   # NOT the DB DSN
#   oidc -> any OIDC provider (WorkOS AuthKit, Descope, Auth0, ...):
#     MCP_OAUTH_PROVIDER=oidc
#     MCP_OIDC_CONFIG_URL=https://<issuer>/.well-known/openid-configuration
#     MCP_OIDC_CLIENT_ID=...
#     MCP_OIDC_CLIENT_SECRET=...
MCP_OAUTH_PROVIDER=
MCP_BASE_URL=
SUPABASE_PROJECT_URL=
MCP_OIDC_CONFIG_URL=
MCP_OIDC_CLIENT_ID=
MCP_OIDC_CLIENT_SECRET=

# HTTP bind address for the FastMCP server (defaults shown; Cloud Run sets PORT).
MCP_HOST=0.0.0.0
MCP_PORT=8000
