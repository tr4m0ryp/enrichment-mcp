# enrichment_mcp server environment. Copy to .env and fill in real values.

# Full Postgres DSN for the Supabase lead store (required).
SUPABASE_DB_URL=postgresql://HOST:5432/DBNAME

# Prospeo enrich-person API keys, comma-separated (free-tier key pool).
PROSPEO_API_KEYS=key_one,key_two

# Pull mobile numbers too (costs 10x credits). Leave false for email+LinkedIn.
PROSPEO_ENRICH_MOBILE=false

# MyEmailVerifier API key for the guess+verify fallback (verify_email tool).
MYEMAILVERIFIER_API_KEY=your_myemailverifier_key

# Static bearer token the MCP server requires on every request.
MCP_BEARER_TOKEN=generate_a_long_random_token

# HTTP bind address for the FastMCP server (defaults shown).
MCP_HOST=0.0.0.0
MCP_PORT=8000
