# enrichment_mcp server environment. Copy to .env and fill in real values.

# Full Postgres DSN for the Supabase lead store (required).
SUPABASE_DB_URL=postgresql://HOST:5432/DBNAME

# --- Enrichment chain: Prospeo primary, Apollo failover ---

# Prospeo enrich-person API keys, comma-separated (free-tier key pool).
PROSPEO_API_KEYS=key_one,key_two

# Pull mobile numbers too (costs 10x credits). Leave false for email+LinkedIn.
# Prospeo only -- Apollo's mobile reveal is webhook-delivered and not used.
PROSPEO_ENRICH_MOBILE=false

# Apollo.io API keys, comma-separated -- the failover tier. Used when Prospeo
# is out of credits, has no usable keys, or (per the toggle below) returns no
# match. Leave EMPTY to run Prospeo-only, which is the pre-Apollo behaviour.
# REQUIRES A PAID APOLLO PLAN: free and trial plans return
# 403 API_INACCESSIBLE on people/match, which retires the key after one probe
# and degrades to Prospeo-only. Verify with:
#   curl -s -X POST https://api.apollo.io/api/v1/people/match \
#     -H "x-api-key: $KEY" -H 'Content-Type: application/json' \
#     -d '{"first_name":"Tim","last_name":"Zheng","domain":"apollo.io"}'
APOLLO_API_KEYS=

# Also fail over when a provider answers "no such person", not just on quota
# exhaustion (default true). Providers hold different databases and bill
# nothing when they return no data, so the second opinion is close to free.
# Set false to spend Apollo credits ONLY when Prospeo is actually down.
CONTACT_FALLBACK_ON_NO_MATCH=true

# QuickEmailVerification API keys, comma-separated (free-tier key pool, 100/day
# each). Primary tier of the guess+verify fallback (verify_email tool).
QUICKEMAILVERIFICATION_API_KEYS=key_one,key_two

# MyEmailVerifier API key -- secondary/fallback tier, used only when the
# QuickEmailVerification pool above is unconfigured or fully exhausted.
MYEMAILVERIFIER_API_KEY=your_myemailverifier_key

# --- Auth: choose ONE mode ---
#
# Mode A (Claude Code): static bearer. Leave MCP_OAUTH_PROVIDER empty and set a
# long random token. Claude Code sends it as an Authorization header.
MCP_BEARER_TOKEN=generate_a_long_random_token
#
# Mode B (claude.ai web connector): OAuth. The web app cannot send a bearer, so
# it needs OAuth. Set MCP_OAUTH_PROVIDER and MCP_BASE_URL (the public https URL
# of THIS server, no /mcp). Pick a provider:
#   authkit (RECOMMENDED) -> WorkOS AuthKit, STATELESS: the server only verifies
#     AuthKit JWTs; claude.ai registers (DCR) and refreshes directly with
#     AuthKit, so restarts/instance recycling never force re-authentication.
#     Enable Dynamic Client Registration in the WorkOS dashboard first.
#     MCP_OAUTH_PROVIDER=authkit
#     WORKOS_AUTHKIT_DOMAIN=https://<name>.authkit.app
#   workos -> WorkOS AuthKit via FastMCP's OAuth proxy. STATEFUL: client
#     registrations + token mappings live in the instance and die with it --
#     avoid on ephemeral hosts (Cloud Run).
#     MCP_OAUTH_PROVIDER=workos
#     WORKOS_AUTHKIT_DOMAIN=https://<name>.authkit.app
#     WORKOS_CLIENT_ID=client_...
#     WORKOS_CLIENT_SECRET=sk_...    # the WorkOS API key
#     # then add <MCP_BASE_URL>/auth/callback to the WorkOS app's redirect URIs
#   oidc -> any OIDC provider (Descope, Auth0, Google, ...):
#     MCP_OAUTH_PROVIDER=oidc
#     MCP_OIDC_CONFIG_URL=https://<issuer>/.well-known/openid-configuration
#     MCP_OIDC_CLIENT_ID=...
#     MCP_OIDC_CLIENT_SECRET=...
#   supabase -> reuse the project's own Supabase Auth (only if the project
#     advertises an OAuth registration endpoint; many do not):
#     MCP_OAUTH_PROVIDER=supabase
#     SUPABASE_PROJECT_URL=https://<ref>.supabase.co   # NOT the DB DSN
MCP_OAUTH_PROVIDER=
MCP_BASE_URL=
WORKOS_AUTHKIT_DOMAIN=
WORKOS_CLIENT_ID=
WORKOS_CLIENT_SECRET=
SUPABASE_PROJECT_URL=
MCP_OIDC_CONFIG_URL=
MCP_OIDC_CLIENT_ID=
MCP_OIDC_CLIENT_SECRET=

# Lead partition this instance serves: pentest | avelero (default pentest). Sets
# the default `project` for every lead-store tool call so the two pipelines' leads
# never commingle. Run one instance per project, or share one and pass `project`
# per call.
LEADS_PROJECT=pentest

# HTTP bind address for the FastMCP server (defaults shown; Cloud Run sets PORT).
MCP_HOST=0.0.0.0
MCP_PORT=8000
